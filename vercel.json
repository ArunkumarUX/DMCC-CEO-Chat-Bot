{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/auth/session", "destination": "/api/auth/session" },
    { "source": "/api/auth/session/:sessionId", "destination": "/api/auth/session/[sessionId]" },
    { "source": "/api/auth/verify", "destination": "/api/auth/verify" },
    { "source": "/api/auth/validate", "destination": "/api/auth/validate" },
    { "source": "/api/auth/login", "destination": "/api/auth/login" },
    { "source": "/api/snapshot", "destination": "/api/snapshot" },
    { "source": "/api/executive/snapshot", "destination": "/api/executive/snapshot" },
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/slideai", "destination": "/api/slideai" },
    { "source": "/api/docai", "destination": "/api/docai" },
    { "source": "/api/presentation", "destination": "/api/[...path]" },
    { "source": "/api/decks", "destination": "/api/[...path]" },
    { "source": "/api/decks/:path*", "destination": "/api/[...path]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/build-info.json",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
