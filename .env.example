# Copy to .env.local and add your key (never commit .env.local)
ANTHROPIC_API_KEY=sk-ant-api03-...
# Perceptis API — board-ready native .pptx (Business/Enterprise plan)
PERCEPTIS_API_KEY=
PERCEPTIS_API_BASE_URL=https://app.perceptis.ai
# Optional: Perceptis template name for branded deck output (see Perceptis dashboard)
PERCEPTIS_TEMPLATE_NAME=

# Optional: dedicated model for SlideAI (defaults to ANTHROPIC_MODEL)
# SLIDEAI_ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
# Live Bloomberg headlines on refresh (optional — see docs/DATA-TRUST-QC.md)
# APIFY_TOKEN=
API_PORT=8787

# Legacy PIN (QR flow only, if re-enabled)
ADGM_ACCESS_PIN=9898

# Frontend: set false to force demo-only mode
VITE_USE_CLAUDE_API=true

# Local only — Create PPT / SlideAI (DO NOT enable on Netlify until docs/CREATE-PPT-PRODUCTION-CHECKLIST.md is signed off)
# VITE_ENABLE_PPT_MASTER=true

# Local only — Architecture page (off on production Netlify builds)
# VITE_ENABLE_ARCHITECTURE=true

# After enabling locally, verify before any deploy:
# npm run verify:slideai
# npm run verify:slideai -- --live

# Apify — Bloomberg news scraper (MCP + server refresh)
# Get token: https://console.apify.com/account/integrations
APIFY_TOKEN=
# Optional: comma-separated Bloomberg category URLs (defaults: markets, economics, crypto, technology)
# APIFY_BLOOMBERG_URLS=https://www.bloomberg.com/markets,https://www.bloomberg.com/crypto
# APIFY_BLOOMBERG_MAX_ITEMS=5

# Netlify production: add the same variables in
# Site settings → Environment variables (ANTHROPIC_API_KEY required for live chat)
