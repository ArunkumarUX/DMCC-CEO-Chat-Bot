# Copy to .env.local and add your key (never commit .env.local)
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional: dedicated model for SlideAI (defaults to ANTHROPIC_MODEL)
# SLIDEAI_ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514
API_PORT=8787
VITE_PORT=5173

# QR / mobile verify — defaults to 9898 in dev
ADGM_ACCESS_PIN=9898

# Optional: force QR link origin (e.g. http://192.168.1.42:5173) if auto-detect fails
# VITE_PUBLIC_ORIGIN=http://192.168.1.42:5173

# Frontend: set false to force demo-only mode
VITE_USE_CLAUDE_API=true

# Local only — Create PPT / SlideAI (DO NOT enable on Netlify until docs/CREATE-PPT-PRODUCTION-CHECKLIST.md is signed off)
# VITE_ENABLE_PPT_MASTER=true

# Local only — Architecture page (off on production Netlify builds)
# VITE_ENABLE_ARCHITECTURE=true

# After enabling locally, verify before any deploy:
# npm run verify:slideai
# npm run verify:slideai -- --live

# Netlify production: add the same variables in
# Site settings → Environment variables (ANTHROPIC_API_KEY required for live chat)
